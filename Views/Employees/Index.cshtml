@model IEnumerable<IT15_LabExam_Tero.Models.Employee>

@{
    ViewData["Title"] = "Employees";
}

<div class="page-card">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h2 class="mb-1">Employee Roster</h2>
            <p class="text-muted mb-0">Manage employee records and access payroll history.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">Add Employee</a>
    </div>

    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Employee</th>
                    <th>Position</th>
                    <th>Department</th>
                    <th>Daily Rate</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">No employees yet. Add your first employee to
                            start processing payroll.</td>
                        </tr>
                    }
                else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@item.FirstName @item.LastName</div>
                                    <small class="text-muted">ID: @item.EmployeeId</small>
                                </td>
                                <td>@item.Position</td>
                                <td>@item.Department</td>
                                <td>@item.DailyRate.ToString("C")</td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@item.EmployeeId"
                                       class="btn btn-sm btn-outline-primary">Details</a>
                                    <a asp-action="Edit" asp-route-id="@item.EmployeeId"
                                       class="btn btn-sm btn-outline-secondary">Edit</a>
                                    <a asp-controller="Payrolls" asp-action="History" asp-route-id="@item.EmployeeId"
                                       class="btn btn-sm btn-outline-success">Payroll</a>
                                    <a asp-action="Delete" asp-route-id="@item.EmployeeId"
                                       class="btn btn-sm btn-outline-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>