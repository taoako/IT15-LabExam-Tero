@model IT15_LabExam_Tero.Models.Payroll

@{
    ViewData["Title"] = "Payroll Details";
}

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Payroll Details</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>

    <dl class="row mb-0">
        <dt class="col-sm-3">Payroll ID</dt>
        <dd class="col-sm-9">@Model.PayrollId</dd>

        <dt class="col-sm-3">Employee</dt>
        <dd class="col-sm-9">@(Model.Employee == null ? "-" : $"{Model.Employee.FirstName} {Model.Employee.LastName}")</dd>

        <dt class="col-sm-3">Date</dt>
        <dd class="col-sm-9">@Model.Date.ToShortDateString()</dd>

        <dt class="col-sm-3">Days Worked</dt>
        <dd class="col-sm-9">@Model.DaysWorked</dd>

        <dt class="col-sm-3">Gross Pay</dt>
        <dd class="col-sm-9">@Model.GrossPay.ToString("C")</dd>

        <dt class="col-sm-3">Deduction</dt>
        <dd class="col-sm-9">@Model.Deduction.ToString("C")</dd>

        <dt class="col-sm-3">Net Pay</dt>
        <dd class="col-sm-9 fw-semibold text-success">@Model.NetPay.ToString("C")</dd>
    </dl>

    <div class="mt-4 d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.PayrollId" class="btn btn-primary">Edit Payroll</a>
        <a asp-action="Delete" asp-route-id="@Model.PayrollId" class="btn btn-outline-danger">Delete</a>
    </div>
</div>
